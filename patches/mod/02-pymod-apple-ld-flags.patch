diff --git a/libs/pymod/CMakeLists.txt b/libs/pymod/CMakeLists.txt
index 9ba69d9..d87582d 100644
--- a/libs/pymod/CMakeLists.txt
+++ b/libs/pymod/CMakeLists.txt
@@ -13,11 +13,15 @@ target_include_directories(pymod
         $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
         $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/src>)
 target_link_libraries(pymod PUBLIC mod::pymodutils)
-target_link_libraries(pymod PRIVATE
-        $<$<CXX_COMPILER_ID:GNU>:-Wl,--no-undefined>
-        $<$<CXX_COMPILER_ID:Clang>:-Wl,--no-undefined>
-        #$<$<CXX_COMPILER_ID:AppleClang>:-Wl,--no-undefined> # TODO: is there an equivalent?
-        )
+# On Darwin, pymodutils already injects -undefined,dynamic_lookup so Python
+# symbols are resolved from the running interpreter (libpython is statically
+# linked into the python binary). Adding -undefined,error here would conflict.
+if(NOT APPLE)
+    target_link_libraries(pymod PRIVATE
+            $<$<CXX_COMPILER_ID:GNU>:-Wl,--no-undefined>
+            $<$<CXX_COMPILER_ID:Clang>:-Wl,--no-undefined>
+            )
+endif()
 set_target_properties(pymod PROPERTIES INSTALL_RPATH "${CMAKE_INSTALL_FULL_LIBDIR}")
 target_compile_options(pymod PRIVATE -Wall -Wextra -pedantic
         -Wno-unused-parameter
